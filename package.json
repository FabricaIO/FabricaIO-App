{
  "name": "fabricaio-app",
  "version": "0.2.8",
  "description": "App for configuring Fabrica-IO devices",
  "productName": "Fabrica-IO App",
  "author": "Sam Groveman <Groveman@fabrica-io.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@quasar/cli": "^2.5.0",
    "@quasar/extras": "^1.17.0",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.3",
    "node-gyp": "^12.2.0",
    "quasar": "^2.18.6",
    "remove": "^0.1.5",
    "serialport": "^13.0.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@eslint/js": "^9.39.3",
    "@quasar/app-vite": "^2.4.1",
    "@types/node": "^25.3.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.24",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite-plugin-checker": "^0.12.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FabricaIO/FabricaIO-App.git"
  }
